    {
      "plugin_id": "git-activity",
      "name": "Git Activity",
      "name_i18n": {
        "zh-CN": "Git 活动"
      },
      "version": "0.1.0",
      "path": "plugins/git_activity",
      "description": "Tracks your Git commits and repository checkouts so Magi can understand your coding projects and development workflow.",
      "description_i18n": {
        "zh-CN": "追踪 Git 提交和分支操作，帮助 Magi 了解你的开发项目和工作流"
      },
      "author": "Magi Team",
      "official": true,
      "contribution_types": [
        "sensor"
      ],
      "platforms": [
        "macos",
        "windows"
      ],
      "suggestion_descriptor": {
        "category": "code_activity",
        "platform_support": [
          "darwin",
          "win32"
        ],
        "setup_time_estimate_seconds": 15,
        "data_locality": "local_only",
        "triggers": {
          "intents": [],
          "entities": [],
          "keywords": {
            "zh": [
              "代码",
              "提交",
              "commit",
              "改了什么",
              "项目",
              "仓库",
              "repo",
              "git",
              "写了什么"
            ],
            "en": [
              "code",
              "commit",
              "changed",
              "repo",
              "repository",
              "project",
              "git",
              "pull request"
            ]
          }
        },
        "rationale": {
          "zh": "magi 能看到你的代码改动和项目进度",
          "en": "Lets magi see what you've been building"
        },
        "local_requirements": [
          {
            "check_kind": "executable_in_path",
            "names": [
              "git",
              "git.exe"
            ]
          }
        ]
      }
    },

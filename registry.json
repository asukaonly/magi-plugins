{
  "registry_version": "2",
  "repo_url": "https://github.com/asukaonly/magi-plugins.git",
  "plugins": [
    {
      "plugin_id": "browser_history_core",
      "name": "Browser History Core",
      "name_i18n": {
        "zh-CN": "浏览器历史核心库"
      },
      "version": "0.1.0",
      "path": "plugins/browser_history_core",
      "description": "Shared ingestion primitives consumed by Chrome/Firefox/Edge history plugins. Installed automatically as a dependency; not user-toggleable.",
      "description_i18n": {
        "zh-CN": "Chrome/Firefox/Edge 历史插件共用的解析逻辑。作为依赖自动安装，无需手动启用。"
      },
      "author": "Magi Team",
      "official": true,
      "kind": "library",
      "contribution_types": [],
      "platforms": [
        "windows",
        "macos"
      ]
    },
    {
      "plugin_id": "calendar",
      "name": "Calendar",
      "name_i18n": {
        "zh-CN": "日历"
      },
      "version": "0.1.1",
      "path": "plugins/calendar_plugin",
      "description": "Reads your calendar events and reminders so Magi can understand your schedule, meetings, and daily plans.",
      "description_i18n": {
        "zh-CN": "读取日历中的事件和提醒，帮助 Magi 了解你的日程安排、会议记录和每日计划"
      },
      "author": "Magi Team",
      "official": true,
      "contribution_types": [
        "sensor"
      ],
      "capabilities": [
        {
          "capability": "calendar",
          "reason_i18n": {
            "en": "Read your calendar events and reminders",
            "zh-CN": "读取你的日历事件与提醒事项"
          }
        },
        {
          "capability": "filesystem_read",
          "scope": [
            "~/Library/Calendars"
          ],
          "reason_i18n": {
            "en": "Parse the local calendar store",
            "zh-CN": "解析本地日历数据"
          }
        }
      ],
      "platforms": [
        "macos"
      ],
      "suggestion_descriptor": {
        "category": "calendar",
        "platform_support": [
          "darwin"
        ],
        "setup_time_estimate_seconds": 10,
        "data_locality": "local_only",
        "triggers": {
          "intents": [],
          "entities": [],
          "keywords": {
            "zh": [
              "日程",
              "日历",
              "会议",
              "安排",
              "约见",
              "提醒",
              "什么时候"
            ],
            "en": [
              "calendar",
              "schedule",
              "meeting",
              "appointment",
              "reminder",
              "agenda"
            ]
          }
        },
        "rationale": {
          "zh": "magi 能看到你的日程，回答'我今天有什么会'这类问题",
          "en": "Lets magi see what's on your calendar"
        },
        "local_requirements": [
          {
            "check_kind": "file_exists",
            "paths_per_platform": {
              "darwin": "~/Library/Calendars"
            }
          }
        ]
      }
    },
    {
      "plugin_id": "chrome-history",
      "name": "Chrome History",
      "name_i18n": {
        "zh-CN": "Chrome 浏览历史"
      },
      "version": "0.1.0",
      "path": "plugins/chrome-history",
      "description": "Reads your local Chrome browsing history so Magi can understand your interests, research habits, and frequently visited sites.",
      "description_i18n": {
        "zh-CN": "读取本地 Chrome 浏览记录，帮助 Magi 了解你的兴趣方向、研究习惯和常访站点"
      },
      "author": "Magi Team",
      "official": true,
      "contribution_types": [
        "sensor"
      ],
      "capabilities": [
        {
          "capability": "filesystem_read",
          "scope": [
            "~/Library/Application Support/Google/Chrome",
            "%LOCALAPPDATA%\\Google\\Chrome"
          ],
          "reason_i18n": {
            "en": "Read the local Chrome history database",
            "zh-CN": "读取本地 Chrome 历史数据库"
          }
        }
      ],
      "platforms": [
        "macos",
        "windows"
      ],
      "suggestion_descriptor": {
        "category": "browser_history",
        "platform_support": [
          "darwin",
          "win32"
        ],
        "setup_time_estimate_seconds": 10,
        "data_locality": "local_only",
        "triggers": {
          "intents": [],
          "entities": [],
          "keywords": {
            "zh": [
              "浏览",
              "上网",
              "看过",
              "网页",
              "网站",
              "搜过",
              "查过"
            ],
            "en": [
              "browsing",
              "browser",
              "website",
              "online",
              "bookmark",
              "browsed",
              "history"
            ]
          }
        },
        "rationale": {
          "zh": "magi 能读取你的 Chrome 历史，帮你回想最近看过什么",
          "en": "Lets magi see what you've been reading in Chrome"
        },
        "local_requirements": [
          {
            "check_kind": "file_exists",
            "paths_per_platform": {
              "darwin": "~/Library/Application Support/Google/Chrome/Default/History",
              "win32": "%LOCALAPPDATA%/Google/Chrome/User Data/Default/History"
            }
          }
        ]
      }
    },

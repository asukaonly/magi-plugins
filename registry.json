      "plugin_id": "photo-library",
      "name": "Photo Library",
      "name_i18n": {
        "zh-CN": "照片库"
      },
      "version": "0.1.0",
      "path": "plugins/photo-library",
      "description": "Scans your local photo library and reads metadata (time, location, camera) so Magi can build a record of your experiences and places visited.",
      "description_i18n": {
        "zh-CN": "扫描本地照片，读取拍摄时间、地点等元数据，帮助 Magi 还原你的生活记录和去过的地方"
      },
      "author": "Magi Team",
      "official": true,
      "contribution_types": [
        "sensor",
        "tool"
      ],
      "platforms": [
        "macos",
        "windows"
      ],
      "suggestion_descriptor": {
        "category": "photos",
        "platform_support": [
          "darwin",
          "win32"
        ],
        "setup_time_estimate_seconds": 20,
        "data_locality": "local_only",
        "triggers": {
          "intents": [],
          "entities": [],
          "keywords": {
            "zh": [
              "照片",
              "图片",
              "拍",
              "相册",
              "拍过",
              "那张",
              "影像",
              "图像"
            ],
            "en": [
              "photo",
              "picture",
              "image",
              "photos",
              "snapshot",
              "album"
            ]
          }
        },
        "rationale": {
          "zh": "magi 能看到你的照片和最近的瞬间",
          "en": "Lets magi see your photos and recent moments"
        },
        "local_requirements": [
          {
            "check_kind": "file_exists",
            "paths_per_platform": {
              "darwin": "~/Pictures",
              "win32": "%USERPROFILE%/Pictures"
            }
          }
        ]
      }
    },
    {
      "plugin_id": "screen-time",
      "name": "App Usage",
      "name_i18n": {
        "zh-CN": "屏幕使用"
      },
      "version": "0.2.6",
      "path": "plugins/screen_time",
      "description": "Tracks which apps you use and for how long, helping Magi understand your work focus, productivity patterns, and daily habits. Records are aggregated by clock hour, so the first entries appear on your timeline only after the current hour ends.",
      "description_i18n": {
        "zh-CN": "记录各应用的使用时长，帮助 Magi 了解你的工作专注情况、效率规律和日常使用习惯。数据按整点小时聚合，第一条记录会在当前所在的整点小时结束后才出现在时间线上。"
      },
      "author": "Magi Team",
      "official": true,
      "contribution_types": [
        "sensor"
      ],
      "platforms": [
        "macos",
        "windows"
      ]
    },

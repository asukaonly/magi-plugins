{
  "photo_library": {
    "name": "照片库",
    "description": "扫描本地照片目录，提取 EXIF 元数据并接入时间线"
  },
  "summary": {
    "basic": "{filename}",
    "with_camera": "{filename} — {camera}",
    "with_camera_params": "{filename} — {camera} {params}",
    "with_camera_params_location": "{filename} — {camera} {params} @ {location}",
    "with_camera_location": "{filename} — {camera} @ {location}",
    "with_location": "{filename} @ {location}",
    "screenshot": "{filename}（截图）",
    "screenshot_with_device": "{filename}（截图 — {device}）"
  }
}
